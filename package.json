{
  "name": "phoenix-history",
  "version": "1.0.0",
  "description": "Extract order history from Phoenix Next",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "concurrently -n API,UI -c cyan,magenta \"node --env-file=.env server.js\" \"vite --config client/vite.config.js\"",
    "server": "node --env-file=.env server.js",
    "orders": "node --env-file=.env src/index.js orders",
    "order-details": "node --env-file=.env src/index.js order-details",
    "sum": "node --env-file=.env src/index.js sum",
    "excel": "node --env-file=.env src/index.js excel"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "concurrently": "^9.2.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1"
  },
  "author": "GallowBell",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.10"
  }
}
