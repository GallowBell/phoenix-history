ORDERS_URL="https://www.phoenixnext.com/sales/order/history/?limit=50"
ORDERS_OUTPUT_FILE="orders.json"
ORDERS_DETAILS_FILE="orders-details.json"
ORDERS_EXCEL_FILE="orders.xlsx"

# Paste the full cookie string from your browser here.
# HOW TO UPDATE:
#   1. Open Chrome DevTools → Network tab
#   2. Navigate to https://www.phoenixnext.com/sales/order/history/
#   3. Find the request, right-click → Copy → Copy as cURL
#   4. Extract the value after -b '...' and paste it below
ORDERS_COOKIE="your_cookie_string_here"

# Web UI server port (default: 3001)
SERVER_PORT=3001
